# Link Builder Configuration
# Copy to .env and fill in values

# App
APP_NAME=LinkBuilder
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-random-string
JWT_SECRET_KEY=change-me-to-random-string
ALLOW_REGISTRATION=false

# Database
DATABASE_URL=sqlite:///./data/linkbuilder.db

# Ahrefs API
AHREFS_API_KEY=your-ahrefs-mcp-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Operational Agent
AGENT_MODEL=opus
AGENT_MAX_RESULTS=20
AGENT_CLAUDE_CLI_PATH=/home/slither/.local/bin/claude
AGENT_CLAUDE_CLI_TIMEOUT_SECONDS=60
AGENT_CLAUDE_CLI_CWD=/tmp

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# CamHours API
CAMHOURS_API_KEY=xxxxxxxxxxxx

# Image APIs
PEXELS_API_KEY=xxxxxxxxxxxx
FAL_API_KEY=xxxxxxxxxxxx

# Email (Resend - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM_NAME=Your Name
EMAIL_FROM_ADDRESS=outreach@yourdomain.com  # Must be verified in Resend

# Email (IMAP/SMTP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
EMAIL_ACCOUNT=outreach@yourdomain.com
EMAIL_PASSWORD=app-password

# Payment
PAYPAL_ADDRESS=publisher-payments@example.com

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Search
BRAVE_API_KEY=xxxxxxxxxxxx

# Rate Limiting
SCRAPE_DELAY_SECONDS=2
AHREFS_REQUESTS_PER_MINUTE=30
